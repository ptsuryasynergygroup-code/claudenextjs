# =============================================================================
# EOS — Environment variables
# Copy to .env  (NOT .env.local) — the Prisma CLI only reads .env, and Next.js
# reads it too. Never commit secrets (.env is git-ignored).
# =============================================================================

# PostgreSQL connection — local Postgres OR a hosted provider (Neon/Supabase/Railway).
# Local example: postgresql://postgres:postgres@localhost:5432/eos_dev
# Neon example:  postgresql://user:pass@ep-xyz.region.aws.neon.tech/eos?sslmode=require
DATABASE_URL=

# Auth.js v5 — generate with: npx auth secret
# Or:                          openssl rand -base64 32
AUTH_SECRET=

# Auth.js v5 — base URL of the app
# Dev: http://localhost:3000
# Prod: https://eos.your-domain.com
AUTH_URL=http://localhost:3000

# Optional: trusted origins for CSRF (comma-separated). Usually leave blank in dev.
# AUTH_TRUST_HOST=true

# Operator (vendor) entitlement server. When BOTH are set and reachable, the
# operator decides which modules/features this client may use. If unset or
# unreachable, the client falls back to its local organization_modules table.
# OPERATOR_URL=https://operator.yourdomain.com
# CLIENT_API_KEY=

