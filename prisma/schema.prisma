// EOS Phase 1 schema — Foundation (Organization, IAM, Entitlement, AuditLog).
// See EOS_PRD_FOR_CLAUDE.md §7 for per-module spec and EOS_Foundation_ERD.txt.
//
// Conventions:
// - Every tenant entity has organizationId + soft-delete (deletedAt).
// - Columns are snake_case via @map. TS fields are camelCase.
// - Indexes: ([organizationId]) + ([organizationId, deletedAt]) on every tenant table.
// - PII fields are marked with /// @pii so lib/audit/redact.ts can find them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. ORGANIZATION DOMAIN
// =============================================================================

model Organization {
  id         String    @id @default(cuid())
  name       String
  code       String    @unique
  /// @pii
  taxNumber  String?   @map("tax_number")
  /// @pii
  address    String?
  /// @pii
  phone      String?
  /// @pii
  email      String?
  website    String?
  status     OrgStatus @default(ACTIVE)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  branches              Branch[]
  departments           Department[]
  users                 User[]
  roles                 Role[]
  auditLogs             AuditLog[]
  organizationPackages  OrganizationPackage[]
  organizationModules   OrganizationModule[]
  organizationFeatures  OrganizationFeature[]
  workflows             Workflow[]
  workflowInstances     WorkflowInstance[]
  notifications         Notification[]
  documents             Document[]
  projects              Project[]
  tasks                 Task[]
  employees             Employee[]
  attendances           Attendance[]
  leaveRequests         LeaveRequest[]
  accounts              LedgerAccount[]
  transactions          Transaction[]
  invoices              Invoice[]
  payments              Payment[]
  vendors               Vendor[]
  purchaseRequests      PurchaseRequest[]
  purchaseOrders        PurchaseOrder[]
  customers             Customer[]
  leads                 Lead[]
  opportunities         Opportunity[]
  quotations            Quotation[]
  salesOrders           SalesOrder[]
  products              Product[]
  warehouses            Warehouse[]
  stocks                Stock[]
  stockMovements        StockMovement[]
  assets                Asset[]
  assetMaintenances     AssetMaintenance[]
  risks                 Risk[]
  riskControls          RiskControl[]
  kpis                  Kpi[]

  @@index([deletedAt])
  @@map("organizations")
}

enum OrgStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  SUSPENDED @map("suspended")

  @@map("org_status")
}

model Branch {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  name           String
  code           String
  /// @pii
  address        String?
  /// @pii
  phone          String?
  manager        String?
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  departments  Department[]
  users        User[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("branches")
}

model Department {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  branchId       String?     @map("branch_id")
  parentId       String?     @map("parent_id")
  name           String
  code           String
  description    String?
  headCount      Int         @default(0) @map("head_count")
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  parent       Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children     Department[] @relation("DepartmentTree")
  positions    Position[]
  users        User[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([branchId])
  @@map("departments")
}

model Position {
  id           String      @id @default(cuid())
  departmentId String      @map("department_id")
  name         String
  code         String
  level        Int         @default(1)
  description  String?
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  users      User[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@index([departmentId, deletedAt])
  @@map("positions")
}

enum EntityStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("entity_status")
}

// =============================================================================
// 2. IDENTITY & ACCESS (User + Auth.js v5)
// =============================================================================

model User {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  branchId       String?    @map("branch_id")
  departmentId   String?    @map("department_id")
  positionId     String?    @map("position_id")
  employeeCode   String?    @map("employee_code")
  name           String
  /// @pii
  email          String     @unique
  emailVerified  DateTime?  @map("email_verified")
  /// @pii
  phone          String?
  /// @pii
  passwordHash   String?    @map("password_hash")
  image          String?
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?  @map("last_login_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  position     Position?    @relation(fields: [positionId], references: [id], onDelete: Restrict)

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]
  auditLogs AuditLog[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("users")
}

enum UserStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  SUSPENDED @map("suspended")

  @@map("user_status")
}

// Auth.js v5 standard models — tenant-less by design.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// 3. ROLE & PERMISSION (RBAC)
// =============================================================================

model Role {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  code           String
  description    String?
  isSystem       Boolean      @default(false) @map("is_system")
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("roles")
}

// Permissions are global (system-defined), shared across all orgs.
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "users.create", "audit-log.export"
  module      String   // module code, e.g. "users"
  action      String   // verb, e.g. "create"
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// =============================================================================
// 4. AUDIT LOG
// =============================================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  userName       String   @map("user_name") // denormalized snapshot
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String // "create" | "update" | "delete" | "login" | "logout" | "view" | "export" | "approve" | "reject"
  description    String?
  oldValue       Json?    @map("old_value")
  newValue       Json?    @map("new_value")
  /// @pii
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// =============================================================================
// 5. ENTITLEMENT (Modules / Features / Packages / Org-grants)
// =============================================================================

model Module {
  id           String   @id @default(cuid())
  code         String   @unique // e.g. "organization", "audit-log", "purchase-order"
  name         String
  description  String?
  status       String   @default("active") // active | deprecated | beta
  dependencies String[] // module codes this depends on
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  features            Feature[]
  packageModules      PackageModule[]
  organizationModules OrganizationModule[]

  @@map("modules")
}

model Feature {
  id          String   @id @default(cuid())
  moduleId    String   @map("module_id")
  code        String   @unique // e.g. "documents.ocr", "documents.digital-signature"
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  module               Module                @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  packageFeatures      PackageFeature[]
  organizationFeatures OrganizationFeature[]

  @@index([moduleId])
  @@map("features")
}

model Package {
  id          String   @id @default(cuid())
  code        String   @unique // "core" | "business" | "advanced" | "singularity"
  name        String
  description String?
  tier        Int      @default(1)
  userLimit   Int?     @map("user_limit")
  storageGb   Int?     @map("storage_gb")
  aiCredits   Int?     @map("ai_credits")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  packageModules       PackageModule[]
  packageFeatures      PackageFeature[]
  organizationPackages OrganizationPackage[]

  @@map("packages")
}

model PackageModule {
  packageId String @map("package_id")
  moduleId  String @map("module_id")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([packageId, moduleId])
  @@index([moduleId])
  @@map("package_modules")
}

model PackageFeature {
  packageId String @map("package_id")
  featureId String @map("feature_id")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([packageId, featureId])
  @@index([featureId])
  @@map("package_features")
}

model OrganizationPackage {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  packageId      String    @map("package_id")
  startsAt       DateTime  @default(now()) @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  status         String    @default("active") // active | expired | cancelled
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  package      Package      @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@map("organization_packages")
}

// Per-org module activation (denormalized for fast entitlement check).
model OrganizationModule {
  organizationId String   @map("organization_id")
  moduleId       String   @map("module_id")
  enabled        Boolean  @default(true)
  source         String   @default("package") // "package" | "override"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([organizationId, moduleId])
  @@index([moduleId])
  @@map("organization_modules")
}

model OrganizationFeature {
  organizationId String   @map("organization_id")
  featureId      String   @map("feature_id")
  enabled        Boolean  @default(true)
  source         String   @default("package") // "package" | "override"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feature      Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([organizationId, featureId])
  @@index([featureId])
  @@map("organization_features")
}

enum WorkflowInstanceStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("workflow_instance_status")
}

enum ApprovalDecision {
  APPROVE @map("approve")
  REJECT  @map("reject")

  @@map("approval_decision")
}

model Workflow {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  description    String?
  entityType     String       @map("entity_type")
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  steps        WorkflowStep[]
  instances    WorkflowInstance[]

  @@unique([organizationId, entityType])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("workflows")
}

model WorkflowStep {
  id              String  @id @default(cuid())
  workflowId      String  @map("workflow_id")
  stepOrder       Int     @map("step_order")
  name            String
  slaHours        Int?    @map("sla_hours")
  escalationHours Int?    @map("escalation_hours")

  workflow  Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approvers WorkflowApprover[]

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@map("workflow_steps")
}

model WorkflowApprover {
  id             String  @id @default(cuid())
  workflowStepId String  @map("workflow_step_id")
  roleId         String? @map("role_id")
  userId         String? @map("user_id")

  step WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)

  @@index([workflowStepId])
  @@map("workflow_approvers")
}

model WorkflowInstance {
  id               String                 @id @default(cuid())
  organizationId   String                 @map("organization_id")
  workflowId       String                 @map("workflow_id")
  entityType       String                 @map("entity_type")
  entityId         String                 @map("entity_id")
  status           WorkflowInstanceStatus @default(PENDING)
  currentStepOrder Int                    @default(1) @map("current_step_order")
  startedBy        String                 @map("started_by")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  completedAt      DateTime?              @map("completed_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  workflow     Workflow         @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  actions      ApprovalAction[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, entityType, entityId])
  @@map("workflow_instances")
}

model ApprovalAction {
  id         String           @id @default(cuid())
  instanceId String           @map("instance_id")
  stepOrder  Int              @map("step_order")
  actorId    String           @map("actor_id")
  decision   ApprovalDecision
  comment    String?
  createdAt  DateTime         @default(now()) @map("created_at")

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("approval_actions")
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  title          String
  message        String
  channel        String    @default("in_app")
  entityType     String?   @map("entity_type")
  entityId       String?   @map("entity_id")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([organizationId, createdAt])
  @@map("notifications")
}

enum DocumentStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

  @@map("document_status")
}

model Document {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  title          String
  documentType   String         @map("document_type")
  status         DocumentStatus @default(DRAFT)
  uploadedBy     String         @map("uploaded_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  versions     DocumentVersion[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  version    Int
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @default(0) @map("file_size")
  mimeType   String   @map("mime_type")
  notes      String?
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

enum ProjectStatus {
  ACTIVE    @map("active")
  ON_HOLD   @map("on_hold")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")

  @@map("project_status")
}

model Project {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  ownerId        String?       @map("owner_id")
  startDate      DateTime?     @map("start_date")
  endDate        DateTime?     @map("end_date")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  milestones   Milestone[]
  tasks        Task[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("projects")
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  name      String
  dueDate   DateTime? @map("due_date")
  sortOrder Int       @default(1) @map("sort_order")
  completed Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@map("milestones")
}

enum TaskStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  DONE        @map("done")
  CANCELLED   @map("cancelled")

  @@map("task_status")
}

enum TaskPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("task_priority")
}

model Task {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String?      @map("project_id")
  milestoneId    String?      @map("milestone_id")
  title          String
  description    String?
  assignedToId   String?      @map("assigned_to_id")
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?    @map("due_date")
  createdById    String       @map("created_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone    Milestone?   @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, assignedToId])
  @@map("tasks")
}

enum EmploymentStatus {
  PERMANENT  @map("permanent")
  CONTRACT   @map("contract")
  PROBATION  @map("probation")
  TERMINATED @map("terminated")

  @@map("employment_status")
}

model Employee {
  id               String           @id @default(cuid())
  organizationId   String           @map("organization_id")
  userId           String?          @unique @map("user_id")
  employeeCode     String           @map("employee_code")
  joinDate         DateTime         @map("join_date")
  employmentStatus EmploymentStatus @default(PERMANENT) @map("employment_status")
  /// @pii
  basicSalary      Int?             @map("basic_salary")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  attendances   Attendance[]
  leaveRequests LeaveRequest[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("employees")
}

model Attendance {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  employeeId     String    @map("employee_id")
  date           DateTime
